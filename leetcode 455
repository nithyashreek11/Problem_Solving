class Solution {
    public int findContentChildren(int[] g, int[] s) {
        if(s==null || s.length==0) {
            return 0;
        }
        Arrays.sort(g);Arrays.sort(s);
        int i=g.length-1,j=s.length-1,cnt=0;
        while(i>=0 && j>=0) {
            if(s[j]>=g[i]) {
                cnt++; i--; j--;
            } else {
                i--;
            }
        }
        return cnt;
    }
}

